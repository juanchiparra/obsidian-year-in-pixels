		"eslint": "^9.39.3",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"svelte": "^5.53.5",
		"svelte-check": "^4.4.3",
		"svelte-preprocess": "^6.0.3",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
